# API Configuration
VITE_API_BASE_URL=http://localhost:3000
VITE_API_TIMEOUT=30000

# PDF Processing (if using external service)
# PDF_SERVICE_API_KEY=your_api_key_here
# PDF_SERVICE_ENDPOINT=https://api.pdfservice.com

# AWS (if deploying to AWS)
# AWS_REGION=us-east-1
# AWS_LAMBDA_FUNCTION_NAME=pdf-editor-api

# Feature Flags
VITE_ENABLE_OFFLINE_MODE=false
VITE_DEBUG_MODE=false

# Note: For production secrets, use:
# - Vercel: Dashboard > Settings > Environment Variables
# - Netlify: Site Settings > Build & Deploy > Environment
# NEVER commit actual API keys or secrets to this repo
